# Backend environment configuration
ENVIRONMENT=development

# PostgreSQL connection string
DATABASE_URL=postgresql://truedata:truedata@postgres:5432/truedata

# JWT signing secret (use a long random value in production)
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS: comma-separated origins, or * for all
BACKEND_CORS_ORIGINS=*

# Storage
STORAGE_BACKEND=local
STORAGE_ROOT=storage

# Default seeded SUPERADMIN
SEED_ADMIN_EMAIL=admin@truedata.local
SEED_ADMIN_PASSWORD=ChangeMe@123
