# Root environment example for docker-compose.
# Copy values into backend/.env and frontend/.env for local (non-Docker) dev.

# PostgreSQL
POSTGRES_USER=truedata
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=truedata

# Backend
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-secret
BACKEND_CORS_ORIGINS=*
STORAGE_BACKEND=local
STORAGE_ROOT=storage
SEED_ADMIN_EMAIL=admin@truedata.local
SEED_ADMIN_PASSWORD=ChangeMe@123

# Frontend
VITE_API_BASE_URL=/api/v1
